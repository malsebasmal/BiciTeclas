---
import Services from "@components/Services.astro"
import ServicesOfferts from "@utils/ServicesOfferts";

const [s1, s2, s3, s4, s5] = ServicesOfferts;
---

<section class="w-full grid grid-cols-3 grid-rows-3 gap-4">
	<div class="">
		<Services
			styles="rounded-2xl flex flex-col items-start justify-between gap-4"
			imageSrcBackground={s1.imageSrcBackground}
			imageIcon={s1.imageIcon}
			iconSize={48}
			title={s1.name}
			description={s1.description}
			price={s1.price} />
	</div>
	<div class="row-span-2">
		<Services
			styles="rounded-2xl flex flex-col items-start justify-end gap-4"
			imageSrcBackground={s2.imageSrcBackground}
			imageIcon={s2.imageIcon}
			iconSize={48}
			title={s2.name}
			description={s2.description}
			price={s2.price} />
	</div>
	<div class="row-span-3">
		<Services
			styles="rounded-2xl flex flex-col items-center justify-between gap-4"
			imageSrcBackground={s3.imageSrcBackground}
			imageIcon={s3.imageIcon}
			iconSize={48}
			title={s3.name}
			description={s3.description}
			price={s3.price} />
	</div>
	<div class="col-start-2 row-start-3">
		<Services
			styles="rounded-2xl flex flex-col items-start justify-between gap-4"
			imageSrcBackground={s4.imageSrcBackground}
			imageIcon={s4.imageIcon}
			iconSize={48}
			title={s4.name}
			description={s4.description}
			price={s4.price} />
	</div>
	<div class="row-span-2 col-start-1 row-start-2">
		<Services
			styles="rounded-2xl flex flex-col items-start justify-between gap-4"
			imageSrcBackground={s5.imageSrcBackground}
			imageIcon={s5.imageIcon}
			iconSize={48}
			title={s5.name}
			description={s5.description}
			price={s5.price} />
	</div>
</section>